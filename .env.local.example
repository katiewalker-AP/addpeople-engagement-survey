# ─── Survey submission ───────────────────────────────────────────────────────
# The URL of your deployed Google Apps Script Web App
# Get this after deploying apps-script.js (see README)
# Server-side only — submissions are proxied through /api/submit to avoid CORS
FORM_ENDPOINT=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# ─── Google Sheets (for reading results) ────────────────────────────────────
# API key with Google Sheets API v4 enabled (read-only, no OAuth needed)
# Create at: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_SHEETS_API_KEY=AIzaSy...

# The Google Sheet ID — already set to the engagement survey sheet
GOOGLE_SHEETS_ID=1-0gYSDljette59hXF0YTql0cf06CfMxI34eZh7TDkh4

# ─── NextAuth (for results dashboard) ───────────────────────────────────────
# Random secret string (min 32 chars). Generate one at: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=your-random-secret-here

# Your deployment URL (no trailing slash)
# In development: http://localhost:3000
# In production: https://your-app.vercel.app
NEXTAUTH_URL=http://localhost:3000

# Google OAuth credentials
# Create at: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret
